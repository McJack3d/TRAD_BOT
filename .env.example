# Copy to .env and fill in. Never commit .env.

# Binance API (trade + read; NEVER enable withdrawal)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail App Password recommended)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Runtime
BOT_ENV=paper
BOT_CONFIG=config/paper.yaml
BOT_DB_PATH=data/bot.db
BOT_LOG_LEVEL=INFO
